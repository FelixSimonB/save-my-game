{
  "name": "save-my-game",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.savemygame.app",
    "productName": "Save My Game",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "save-my-game/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "target": "nsis"
    }
  }
}